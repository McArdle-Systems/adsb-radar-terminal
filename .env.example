# Copy this file to `.env` and fill in your values. `.env` is gitignored.
#
#   cp .env.example .env      # then edit
#
RADAR_HOST=your-feeder.local   # hostname/IP of your ADS-B feeder
RADAR_LAT=0.0                  # receiver latitude  (scope center)
RADAR_LON=0.0                  # receiver longitude
RADAR_LABEL=HOME              # label drawn at the scope center
RADAR_SBS_PORT=30003          # readsb/dump1090 SBS (BaseStation) TCP port
